<UserControl
    x:Class="KimiCodeBar.Views.Controls.KimiServerCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KimiCodeBar">

    <Border
        Background="{ThemeResource CardBackgroundBrush}"
        CornerRadius="12">
        <StackPanel Padding="12" Spacing="12">
            <!-- 标题行：名称 + 状态 + 版本 -->
            <Grid>
                <TextBlock
                    Text="Kimi Web"
                    FontSize="13"
                    FontWeight="SemiBold"
                    Foreground="{ThemeResource TextPrimaryBrush}"
                    HorizontalAlignment="Left" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                    <Border x:Name="StatusBadge" Padding="6,2" CornerRadius="4">
                        <TextBlock x:Name="StatusText" FontSize="10" FontWeight="Medium" />
                    </Border>
                    <TextBlock x:Name="VersionText" FontSize="12" FontWeight="Medium"
                               Foreground="{ThemeResource TextSecondaryBrush}" VerticalAlignment="Center" />
                </StackPanel>
            </Grid>

            <!-- 操作按钮 -->
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button x:Name="OpenButton" Grid.Column="0" Content="打开"
                        HorizontalAlignment="Stretch" Click="OnOpenClick" />
                <Button x:Name="ToggleButton" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnToggleClick" />
                <Button x:Name="RestartButton" Grid.Column="2" Content="重启"
                        HorizontalAlignment="Stretch" Click="OnRestartClick" />
            </Grid>
        </StackPanel>
    </Border>

</UserControl>
