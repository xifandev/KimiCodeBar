<UserControl
    x:Class="KimiCodeBar.Views.Controls.LoginOverlay"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:KimiCodeBar">

    <Border
        Background="{ThemeResource PanelBackgroundBrush}"
        Opacity="0.96">
        <StackPanel
            Padding="24"
            Spacing="16"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">
            <!-- 品牌 Logo -->
            <Border
                Width="52" Height="36"
                Background="{ThemeResource KimiBlueBrush}"
                CornerRadius="8">
                <TextBlock
                    Text="K"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center" />
            </Border>

            <TextBlock
                Text="登录后查看 Kimi 用量"
                FontSize="14"
                FontWeight="Medium"
                Foreground="{ThemeResource TextPrimaryBrush}"
                HorizontalAlignment="Center" />

            <Button
                x:Name="ApiKeyButton"
                Content="设置 API Key"
                Click="OnApiKeyClick"
                HorizontalAlignment="Center" />

            <Button
                x:Name="OtherButton"
                Content="其他登录方式"
                Click="OnOtherClick"
                HorizontalAlignment="Center"
                Background="Transparent"
                BorderThickness="0" />
        </StackPanel>
    </Border>

</UserControl>
