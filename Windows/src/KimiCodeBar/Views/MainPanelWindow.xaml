<ex:WindowEx
    x:Class="KimiCodeBar.Views.MainPanelWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ex="using:WinUIEx"
    xmlns:local="using:KimiCodeBar"
    xmlns:controls="using:KimiCodeBar.Views.Controls"
    Title="KimiCodeBar"
    Width="340"
    Height="580">

    <Grid Background="{ThemeResource PanelBackgroundBrush}">
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="16" Spacing="14">
                <!-- 头部 -->
                <Grid>
                    <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <Border
                            Width="40" Height="28"
                            Background="{ThemeResource KimiBlueBrush}"
                            CornerRadius="8">
                            <TextBlock Text="K" FontSize="18" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="KimiCodeBar" FontSize="18" FontWeight="Bold"
                                   Foreground="{ThemeResource TextPrimaryBrush}" />
                    </StackPanel>
                    <Button x:Name="CommunityButton" Content="社区版"
                            HorizontalAlignment="Right" VerticalAlignment="Center"
                            Background="Transparent" BorderThickness="0"
                            Click="OnCommunityClick" />
                </Grid>

                <!-- 用量卡片 -->
                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <controls:UsageCard Grid.Column="0"
                        Title="{x:Bind local:Strings.Get('WeeklyUsage')}"
                        Percentage="{x:Bind ViewModel.Quota.Weekly.Percentage, Mode=OneWay, FallbackValue=0}"
                        ResetText="{x:Bind ViewModel.Quota.Weekly.TimeUntilReset(), Mode=OneWay, FallbackValue=''}"
                        AccentColor="{ThemeResource KimiBlueBrush}"
                        IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />
                    <controls:UsageCard Grid.Column="1"
                        Title="{x:Bind local:Strings.Get('FiveHourUsage')}"
                        Percentage="{x:Bind ViewModel.Quota.FiveHour.Percentage, Mode=OneWay, FallbackValue=0}"
                        ResetText="{x:Bind ViewModel.Quota.FiveHour.TimeUntilReset(), Mode=OneWay, FallbackValue=''}"
                        IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}">
                        <controls:UsageCard.AccentColor>
                            <SolidColorBrush Color="#FFE08A00" />
                        </controls:UsageCard.AccentColor>
                    </controls:UsageCard>
                </Grid>

                <!-- 加油包 -->
                <controls:BoosterWalletCard
                    Wallet="{x:Bind ViewModel.Quota.BoosterWallet, Mode=OneWay}"
                    IsLoading="{x:Bind ViewModel.IsLoading, Mode=OneWay}" />

                <!-- Kimi Web -->
                <controls:KimiServerCard x:Name="ServerCard"
                    State="{x:Bind ViewModel.ServerState, Mode=OneWay}" />

                <!-- 操作按钮 -->
                <Grid ColumnSpacing="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <controls:ActionButton Grid.Column="0" Glyph="&#xE943;" Title="控制台" Click="OnConsoleClick" />
                    <controls:ActionButton Grid.Column="1" Glyph="&#xE72C;" Title="刷新"
                                          Command="{x:Bind ViewModel.RefreshAllCommand}" />
                    <controls:ActionButton Grid.Column="2" Glyph="&#xE713;" Title="设置" Click="OnSettingsClick" />
                    <controls:ActionButton Grid.Column="3" Glyph="&#xE7E8;" Title="退出" Click="OnExitClick" />
                </Grid>

                <!-- CLI 版本行 -->
                <Grid x:Name="CliRow" Padding="14,12" Background="{ThemeResource CardBackgroundBrush}" CornerRadius="12" Tapped="OnCliRowTapped">
                    <TextBlock Text="{x:Bind local:Strings.Get('CliVersion')}" FontSize="13"
                               FontWeight="Medium" Foreground="{ThemeResource TextTertiaryBrush}"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="CliVersionText" FontSize="12" FontWeight="Medium"
                                   Foreground="{ThemeResource TextSecondaryBrush}" />
                        <Border x:Name="CliBadge" Padding="5,1" CornerRadius="4" Visibility="Collapsed">
                            <TextBlock x:Name="CliBadgeText" FontSize="9" FontWeight="Medium" />
                        </Border>
                    </StackPanel>
                </Grid>

                <!-- App 版本行 -->
                <Grid x:Name="AppRow" Padding="14,12" Background="{ThemeResource CardBackgroundBrush}" CornerRadius="12" Tapped="OnAppRowTapped">
                    <TextBlock Text="{x:Bind local:Strings.Get('AppVersionLabel')}" FontSize="13"
                               FontWeight="Medium" Foreground="{ThemeResource TextTertiaryBrush}"
                               VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" Spacing="6" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <TextBlock x:Name="AppVersionText" FontSize="12" FontWeight="Medium"
                                   Foreground="{ThemeResource TextSecondaryBrush}" />
                        <Border x:Name="AppBadge" Padding="5,1" CornerRadius="4" Visibility="Collapsed">
                            <TextBlock x:Name="AppBadgeText" FontSize="9" FontWeight="Medium" />
                        </Border>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- 未登录遮罩 -->
        <controls:LoginOverlay x:Name="LoginOverlayControl" Visibility="Collapsed" />
    </Grid>

</ex:WindowEx>
