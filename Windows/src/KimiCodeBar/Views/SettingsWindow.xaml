<ex:WindowEx
    x:Class="KimiCodeBar.Views.SettingsWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ex="using:WinUIEx"
    xmlns:local="using:KimiCodeBar"
    Title="设置"
    Width="420"
    Height="440">

    <StackPanel Padding="24" Spacing="20" Background="{ThemeResource PanelBackgroundBrush}">
        <TextBlock Text="{x:Bind local:Strings.Get('SettingsTitle')}" FontSize="20" FontWeight="Bold"
                   Foreground="{ThemeResource TextPrimaryBrush}" />

        <!-- API Key -->
        <StackPanel Spacing="8">
            <TextBlock Text="{x:Bind local:Strings.Get('ApiKeyLabel')}" FontSize="13" FontWeight="Medium"
                       Foreground="{ThemeResource TextPrimaryBrush}" />
            <TextBox
                x:Name="ApiKeyBox"
                Text="{x:Bind ViewModel.ApiKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="{x:Bind local:Strings.Get('ApiKeyPlaceholder')}"
                HorizontalAlignment="Stretch" />
        </StackPanel>

        <!-- 主题 -->
        <StackPanel Spacing="8">
            <TextBlock Text="{x:Bind local:Strings.Get('ThemeLabel')}" FontSize="13" FontWeight="Medium"
                       Foreground="{ThemeResource TextPrimaryBrush}" />
            <ComboBox x:Name="ThemeCombo" HorizontalAlignment="Stretch" />
        </StackPanel>

        <!-- 开机自启 -->
        <Grid>
            <TextBlock Text="{x:Bind local:Strings.Get('LaunchAtLogin')}" FontSize="13" FontWeight="Medium"
                       Foreground="{ThemeResource TextPrimaryBrush}" VerticalAlignment="Center"
                       HorizontalAlignment="Left" />
            <ToggleSwitch
                IsOn="{x:Bind ViewModel.LaunchAtLogin, Mode=TwoWay}"
                HorizontalAlignment="Right" />
        </Grid>

        <!-- 操作 -->
        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="CancelButton" Content="{x:Bind local:Strings.Get('Cancel')}" Click="OnCancelClick" />
            <Button x:Name="SaveButton" Content="{x:Bind local:Strings.Get('Save')}" Click="OnSaveClick"
                    Style="{ThemeResource AccentButtonStyle}" />
        </StackPanel>
    </StackPanel>

</ex:WindowEx>
